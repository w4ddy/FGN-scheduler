# Copy this file to .env and fill in your real values.
# .env is already in .gitignore so your real credentials never get committed.

# Your Postgres connection string.
# - Local testing: postgres://postgres:postgres@localhost:5432/fgn_league
# - Neon/Supabase/Render: copy the connection string they give you after creating the database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fgn_league

# Only set this to "disable" if you're connecting to a LOCAL Postgres that has no SSL configured.
# Leave it unset (or delete this line) when connecting to Neon, Supabase, or Render Postgres.
PGSSL=disable

# Optional: change the port the app listens on
PORT=3000
